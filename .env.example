# .env.example — copy to .env and fill in real values
# NEVER commit .env to git

# ── REQUIRED ───────────────────────────────────────────────
# Get your API key from https://rapidapi.com/api-football/api-football
API_FOOTBALL_KEY=your-rapidapi-key-here

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-random-32-character-hex-string-here

# Password for dashboard access (basic auth)
BOOTBALL_PASSWORD=change-this-to-a-secure-password

# ── Flask ────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=0

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# ── Database ─────────────────────────────────────────────
DATABASE_PATH=./data/football.db
SCHEDULER_DB_PATH=./data/scheduler.db

# ── Betting Bot (simulated money only) ───────────────────
# Set to true to auto-place bets (WARNING: uses fake money only)
BOT_ENABLED=false
# Maximum stake per bet in SEK
BOT_MAX_STAKE=50
# Minimum EV threshold to place a bet (5% = 0.05)
BOT_MIN_EV=0.05

# ── ML Models ─────────────────────────────────────────────
MODEL_DIR=./data/models
MIN_CONFIDENCE_THRESHOLD=0.60

# ── Scheduler ─────────────────────────────────────────────
SCHEDULER_ENABLED=true
FETCH_FIXTURES_INTERVAL_HOURS=6
FETCH_RESULTS_INTERVAL_HOURS=1
FETCH_ODDS_INTERVAL_HOURS=2
PREDICTIONS_RUN_HOUR=3
RETRAIN_DAY_OF_WEEK=mon
RETRAIN_HOUR=4

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── CORS (frontend dev servers) ─────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Discord Alerts (optional) ────────────────────────────
# For notifications when bets are placed/completed
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# ── Telegram Alerts (optional) ──────────────────────────
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id