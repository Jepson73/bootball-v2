# .env.example — copy to .env and fill in real values
# NEVER commit .env to git

# ── Flask ──────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-string

# ── Server ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# ── Database ───────────────────────────────────────────
DATABASE_PATH=./data/football.db
SCHEDULER_DB_PATH=./data/scheduler.db

# ── api-football (RapidAPI) ────────────────────────────
API_FOOTBALL_KEY=your-rapidapi-key-here
API_FOOTBALL_HOST=v3.football.api-sports.io
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ── Betting Bot ────────────────────────────────────────
BOT_ENABLED=false
BOT_MAX_STAKE=50
BOT_MIN_EV=0.05

# ── ML ─────────────────────────────────────────────────
MODEL_DIR=./backend/models/saved
MIN_CONFIDENCE_THRESHOLD=0.60

# ── Scheduler ──────────────────────────────────────────
SCHEDULER_ENABLED=true
FETCH_FIXTURES_INTERVAL_HOURS=6
FETCH_RESULTS_INTERVAL_HOURS=1
FETCH_ODDS_INTERVAL_HOURS=2
PREDICTIONS_RUN_HOUR=3
RETRAIN_DAY_OF_WEEK=mon
RETRAIN_HOUR=4

# ── Logging ────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── CORS (frontend dev server) ─────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
