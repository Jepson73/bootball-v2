# weather_cache/: run scripts/analysis/phase5_wave2.py (Open-Meteo, no API key)
# dc_cache/:      run scripts/analysis/dixon_coles_backtest.py
# understat_cache/: run scripts/analysis/phase7_xg_analysis.py
# fdco_cache/:    run scripts/analysis/fdco_backfill.py (downloads from football-data.co.uk)
